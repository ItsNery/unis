                        @php
                            // Combinamos noticias y eventos para mostrar como acciones realizadas
                            $actions = collect();
                            foreach ($news as $n) {
                                $actions->push([
                                    'type' => 'Noticia',
                                    'title' => $n->title,
                                    'date' => $n->published_at ? $n->published_at->format('d/m/Y') : '',
                                    'content' => $n->content,
                                    'image' => $n->image_path,
                                ]);
                            }
                            foreach ($events as $e) {
                                $actions->push([
                                    'type' => 'Evento',
                                    'title' => $e->title,
                                    'date' => $e->event_date ? $e->event_date->format('d/m/Y') : '',
                                    'content' => $e->description,
                                    'image' => $e->image_path,
                                ]);
                            }
                            // Tomar las 3 más recientes
                            $recentActions = $actions->take(3);
                        @endphp

                        @forelse($recentActions as $act)
                            <div @click="openModal('{{ $act['type'] }}', '{{ $act['title'] }}', '{{ $act['date'] }}', '{{ addslashes($act['content']) }}', '{{ $act['image'] }}')"
