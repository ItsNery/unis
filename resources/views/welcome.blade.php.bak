<body class="bg-[#fafaf9] text-slate-800 antialiased font-sans overflow-x-hidden" x-data="{
    showModal: false,
    modalType: '',
    modalTitle: '',
    modalDate: '',
    modalContent: '',
    modalImage: '',
    modalExtra: '',
    openModal(type, title, date, content, image, extra = '') {
        this.modalType = type;
        this.modalTitle = title;
        this.modalDate = date;
        this.modalContent = content;
        this.modalImage = image;
        this.modalExtra = extra;
        this.showModal = true;
    }
}">

